# Slack app credentials (create app at https://api.slack.com/apps — see SETUP.md)
SLACK_BOT_TOKEN=xoxb-REPLACE
SLACK_APP_TOKEN=xapp-REPLACE

# Incoming webhook URL for scheduled-run completion notifications
# Create in Slack app config > Incoming Webhooks; point at #claude-notifications
SLACK_COMPLETION_WEBHOOK=https://hooks.slack.com/services/REPLACE

# Comma-separated Slack user IDs allowed to command the bot.
# Find yours in Slack: click your profile > "Copy member ID" (starts with U...).
# ANYONE NOT IN THIS LIST WILL BE IGNORED.
ALLOWED_USER_IDS=U00000000

# Localhost port for the schedule-manager skill to hit. No token needed; loopback only.
SCHEDULER_PORT=7823
